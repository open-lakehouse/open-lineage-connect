# Optional Cargo registry proxy used by the crates/table-service Docker build.
# Copy your registry URL from ~/.cargo/config.toml if you use a mirror/proxy.
#
# Examples:
# CRATES_PROXY=https://your-cargo-proxy.example.com/index/
# CRATES_PROXY=sparse+https://your-cargo-proxy.example.com/index/

CRATES_PROXY=

# Optional Spark install root used by just run-e2e-demo when spark-submit
# is not already available on PATH.
SPARK_HOME=

# Optional comma-separated repositories passed to spark-submit --repositories.
# Useful behind corporate firewalls where Maven Central is blocked.
# Example:
# SPARK_MAVEN_REPOSITORIES=https://maven-proxy.your-company.com
SPARK_MAVEN_REPOSITORIES=

# Optional token passed to Spark plugin as spark.openlineage.authToken.
# For local demo against this repo's default auth interceptor, use valid-token.
OPENLINEAGE_AUTH_TOKEN=valid-token

# =============================================================================
# ECS / Terraform deployment (terraform/ecs-lineage)
# Used by scripts/deploy-ecs-lineage.sh, which sources this file and exports
# TF_VAR_* for Terraform. `.env` is gitignored; copy from this template.
# =============================================================================
AWS_REGION=us-west-2
OPEN_LINEAGE_NAME_PREFIX=open-lineage

# ECR repositories (created on first push by the ecr-push scripts).
LINEAGE_ECR_REPO=lineage-service
TABLE_ECR_REPO=table-service

# Independent per-service image tags. Bump either one to release that service.
LINEAGE_IMAGE_TAG=v0.1.0
TABLE_IMAGE_TAG=v0.1.0

# Delta storage backend for the table-service: local | s3 | unity.
DELTA_STORAGE=unity
# Only used when DELTA_STORAGE=s3:
DELTA_BUCKET=
DELTA_TABLE_PATH=

# Unity Catalog write target + auth.
UNITY_CATALOG_URL=https://uc.openlakehousedemos.dev
# Fallback service token for vending when no per-user JWT is forwarded (stored
# in Secrets Manager). Leave empty when UC authorization is disabled.
UNITY_CATALOG_TOKEN=
UC_CATALOG=lineage
UC_SCHEMA=lineage
UC_TABLE=events

# Lineage auth: uc-jwt | static | disabled.
LINEAGE_AUTH_MODE=uc-jwt
# Expected token for static mode (e.g. "Bearer my-token"); stored in Secrets
# Manager when set. Ignored in uc-jwt / disabled modes.
LINEAGE_AUTH_TOKEN=

# HTTPS (optional): set both to terminate TLS on the NLB + add a Route 53 alias.
LINEAGE_DOMAIN_NAME=
LINEAGE_HOSTED_ZONE_ID=
LINEAGE_CERT_DOMAIN_NAME=
