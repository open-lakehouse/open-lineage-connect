# If you prefer the allow list template instead of the deny list, see community template:
# https://github.com/github/gitignore/blob/main/community/Golang/Go.AllowList.gitignore
#
# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib
server

# Test binary, built with `go test -c`
*.test

# Code coverage profiles and other test artifacts
*.out
coverage.*
*.coverprofile
profile.cov

# Dependency directories (remove the comment below to include it)
# vendor/

# Go workspace file
go.work
go.work.sum

# vendor directory
vendor/

# env file
.env

# Editor/IDE
# .idea/
# .vscode/

# Cursor IDE — local planning docs, not part of the repo
.cursor/plans/

.DS_Store
*/.DS_Store

# Rust build artifacts
open-lakehouse-table-service/target/
open-lakehouse-table-service/proto-export/

# Spark plugin build artifacts (sbt, Metals, IntelliJ)
spark-openlineage-plugin/target/
spark-openlineage-plugin/project/target/
spark-openlineage-plugin/project/project/
spark-openlineage-plugin/.bsp/
spark-openlineage-plugin/.bloop/
spark-openlineage-plugin/.metals/
spark-openlineage-plugin/project/metals.sbt

# Metals / VSCode workspace (Scala dev tooling)
.metals/
.bloop/
.bsp/
.vscode/

# Local Spark SQL warehouse / Derby artifacts
metastore_db/
derby.log

